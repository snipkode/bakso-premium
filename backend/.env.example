# Server Configuration
PORT=9000
NODE_ENV=development

# Database (MySQL)
DB_HOST=your_vps_ip_or_hostname
DB_PORT=3306
DB_NAME=bakso_db
DB_USER=bakso_user
DB_PASSWORD=your_secure_password

# JWT Secret
JWT_SECRET=bakso_premium_secret_key_2024_change_in_production

# VAPID Keys for Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@bakso.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email Configuration (for PIN reset and notifications)
# For Gmail:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Create an app password for "Mail"
# 3. Use that password in EMAIL_PASSWORD
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=Bakso Premium <your-email@gmail.com>

# Alternative Email Services:
# EMAIL_SERVICE=outlook
# EMAIL_SERVICE=yahoo
# EMAIL_SERVICE=sendgrid
# EMAIL_SERVICE=mailgun

# Upload Settings
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
