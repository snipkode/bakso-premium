{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "categories": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "products": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "orders": {
      ".read": "auth != null",
      "$orderId": {
        ".write": "auth != null"
      }
    },
    "payments": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "vouchers": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "reviews": {
      ".read": true,
      ".write": "auth != null"
    },
    "loyaltyPoints": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "pushSubscriptions": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "queueSettings": {
      ".read": true,
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'kitchen')"
    },
    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
